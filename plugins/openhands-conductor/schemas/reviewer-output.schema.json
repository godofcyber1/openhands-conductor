{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openhands-conductor.local/schemas/reviewer-output.schema.json",
  "title": "ReviewerOutput",
  "type": "object",
  "required": [
    "status",
    "summary",
    "findings",
    "commands_run",
    "risks",
    "next_recommendation"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["done", "failed", "needs_context"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "commands_run": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_recommendation": {
      "type": "string"
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": [
        "title",
        "severity",
        "confidence",
        "evidence",
        "recommendation"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "file": {
          "type": ["string", "null"]
        },
        "line": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "recommendation": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
